NEXT_PUBLIC_SITE_URL="https://getfocushealth.com"

# Cloud SQL (Postgres). Use cloud-sql-proxy locally on 127.0.0.1:5433.
DB_HOST="127.0.0.1"
DB_PORT="5433"
DB_NAME="focus_health"
DB_USER="focus_app"
DB_PASSWORD="replace-me"
# Cloud Run only — connection name for the Cloud SQL Auth Proxy sidecar.
CLOUD_SQL_CONNECTION_NAME="project:region:instance"

# Admin panel credentials (used by /login and /admin)
ADMIN_EMAIL="info@getfocushealth.com"
ADMIN_PASSWORD="Hello@123"
ADMIN_SESSION_SECRET="replace-with-long-random-secret"

# LOP dashboard — HMAC secret for signed session cookies.
LOP_JWT_SECRET="replace-with-64-byte-random-secret"
